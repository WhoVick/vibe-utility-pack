{
  "name": "vibe-utility-pack",
  "version": "0.2.0",
  "description": "Ten local-first, dependency-free maintainer utilities in one GitHub-ready toolkit.",
  "type": "module",
  "private": false,
  "homepage": "https://whovick.github.io/vibe-utility-pack/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhoVick/vibe-utility-pack.git"
  },
  "bugs": {
    "url": "https://github.com/WhoVick/vibe-utility-pack/issues"
  },
  "scripts": {
    "start": "node bin/static-server.mjs",
    "doctor": "node bin/dev-doctor.mjs",
    "repo-health": "node bin/repo-health.mjs",
    "changelog": "node bin/changelog.mjs",
    "check": "node --check app.js && node --check src/core.mjs && node --check tests/core.test.mjs && node --check bin/dev-doctor.mjs && node --check bin/repo-health.mjs && node --check bin/changelog.mjs && node --check bin/static-server.mjs",
    "test": "npm run check && node tests/core.test.mjs"
  },
  "bin": {
    "vibe-doctor": "bin/dev-doctor.mjs",
    "vibe-health": "bin/repo-health.mjs",
    "vibe-changelog": "bin/changelog.mjs"
  },
  "keywords": [
    "developer-tools",
    "productivity",
    "static-site",
    "local-first",
    "github"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
